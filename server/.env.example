# ─────────────────────────────────────────────
# Aditya Builders — Backend Environment Config
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Server
PORT=5000

# MongoDB
MONGO_URI=

# Frontend URL (for CORS)
CLIENT_URL=

# JWT Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Admin Panel
# This slug is used as the URL path for the hidden admin panel.
# Change this to a long, random, unguessable string before going live.
# Example: /panel-a7f3d9k2 (never expose this in any public page)
ADMIN_PANEL_SLUG=

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (Transactional Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Notification Recipient (email address to receive contact form submissions)
NOTIFY_EMAIL_TO=

# Seed Script Credentials (used only when running: npm run seed)
# Change these before running the seed script — these become the admin login credentials.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
